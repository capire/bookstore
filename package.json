{
  "name": "@capire/bookstore",
  "version": "2.0.2",
  "description": "Shows how to reuse and compose with CAP.",
  "repository": "https://github.com/capire/bookstore",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@capire/bookshop": "*",
    "@capire/common": "*",
    "@capire/data-viewer": "*",
    "@capire/orders": "*",
    "@capire/reviews": "*",
    "@sap/cds": ">=8",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1",
    "@cap-js/sqlite": ">=1",
    "@sap/cds-dk": "^9.9.1",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "chest": "chest",
    "jest": "jest",
    "test": "chest"
  },
  "cds": {
    "requires": {
      "messaging": true,
      "db": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "html5-repo": true
    },
    "log": {
      "service": true
    }
  }
}
