{
  "welcomeFile": "/index.html",
  "routes": [
    {
      "source": "^/(index\\.html|appconfig/.*)$",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/(odata|admin)/(.*)$",
      "target": "/$1/$2",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^(/.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
