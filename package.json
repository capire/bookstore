{
  "name": "@capire/bookstore",
  "version": "2.0.1",
  "description": "Shows how to reuse and compose with CAP.",
  "repository": "https://github.com/capire/bookstore",
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@capire/bookshop": "^2.1.7",
    "@capire/common": "^2.0.2",
    "@capire/data-viewer": "^0.1.5",
    "@capire/orders": "^2.0.1",
    "@capire/reviews": "^2.0.2",
    "@sap-cloud-sdk/http-client": "^4.6.0",
    "@sap-cloud-sdk/resilience": "^4.6.0",
    "@sap/cds": "git+https://github.tools.sap/cap/cds#fix/hierarchy-direct-crud-exclusion"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/sqlite": "^2.2.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "chest": "chest",
    "jest": "jest",
    "test": "chest"
  },
  "cds": {
    "requires": {
      "ReviewsService": "odata",
      "OrdersService": "odata",
      "messaging": true,
      "db": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      }
    },
    "log": {
      "service": true
    },
    "fiori": {
      "direct_crud": true
    }
  }
}
